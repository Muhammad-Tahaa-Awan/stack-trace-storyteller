# Groq API key — primary LLM provider for generating the "story" behind a stack trace.
# Get one at https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini API key — fallback LLM provider.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# GitHub personal access token — used to enrich traces with repo/source context.
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=
